generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  password        String?
  country         String?
  timezone        String?
  name            String?
  roleId          String
  status          UserStatus  @default(INACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastSignInAt    DateTime?
  emailVerifiedAt DateTime?
  isTrashed       Boolean     @default(false)
  avatar          String?
  invitedByUserId String?
  isProtected     Boolean     @default(false)
  language        String?     @default("en")
  theme           String?     @default("light")
  accounts        Account[]
  Session         Session[]
  systemLog       SystemLog[]
  role            UserRole    @relation(fields: [roleId], references: [id])

  @@index([invitedByUserId])
  @@index([roleId])
  @@index([status])
}

model UserRole {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String               @unique
  description     String?
  isTrashed       Boolean              @default(false)
  createdByUserId String?
  createdAt       DateTime             @default(now())
  isProtected     Boolean              @default(false)
  isDefault       Boolean              @default(false)
  users           User[]
  permissions     UserRolePermission[]
}

model UserPermission {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String
  description     String?
  createdByUserId String?
  createdAt       DateTime             @default(now())
  roles           UserRolePermission[]
}

model UserRolePermission {
  id           String         @id @default(uuid())
  roleId       String
  permissionId String
  assignedAt   DateTime       @default(now())
  permission   UserPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         UserRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], name: "provider_providerAccountId")
}

model Shelter {
  id            String         @id @default(uuid())
  supervisorId  String
  name          String
  capacity      Int            @default(0)
  area          String
  createdAt     DateTime       @default(now())
  familiesCount Int            @default(0)
  fillStatus    CampFillStatus @default(NOT_FULL)
  isProtected   Boolean        @default(false)
  isTrashed     Boolean        @default(false)
  phone         String
  placeId       String?        @unique
  updatedAt     DateTime       @updatedAt
  place         Place?         @relation("ShelterPlace", fields: [placeId], references: [id])
  supervisor    Supervisor     @relation(fields: [supervisorId], references: [id])

  @@index([supervisorId])
  @@index([fillStatus])
  @@index([name])
  @@index([area])
  @@index([isTrashed])
}

model Camps {
  id                   String         @id @default(uuid())
  name                 String
  area                 String?
  subArea              String?
  capacity             Int            @default(0)
  currentFamiliesCount Int            @default(0)
  status               CampFillStatus @default(NOT_FULL)
  latitude             Decimal?       @db.Decimal(10, 7)
  longitude            Decimal?       @db.Decimal(10, 7)
  supervisorId         String?
  placeId              String?        @unique
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  isTrashed            Boolean        @default(false)
  isProtected          Boolean        @default(false)
  addresses            Address[]
  beneficiaries        Beneficiary[]
  place                Place?         @relation("CampPlace", fields: [placeId], references: [id])
  supervisor           Supervisor?    @relation(fields: [supervisorId], references: [id])
  emergencies          Emergency[]

  @@index([supervisorId])
  @@index([status])
}

model Supervisor {
  id          String        @id @default(uuid())
  name        String
  phone       String?
  createdAt   DateTime      @default(now())
  isProtected Boolean       @default(false)
  isTrashed   Boolean       @default(false)
  status      GeneralStatus @default(ACTIVE)
  updatedAt   DateTime      @updatedAt
  camps       Camps[]
  emergencies Emergency[]
  shelters    Shelter[]

  @@index([status])
}
model Hospital {
  id            String         @id @default(uuid())
  type          HospitalType   // حكومي، وكالة، خاص
  name          String         // اسم المستشفى
  region        Region         // الموقع العام (للفلترة السريعة)
  phone         String
  latitude      Decimal?       @db.Decimal(10, 7)
  longitude     Decimal?       @db.Decimal(10, 7)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // الربط الجديد والمهم: المستشفى يتبع لعنوان/منطقة محددة
  addressId     String
  address       Address        @relation(fields: [addressId], references: [id])

  // باقي علاقاتك كما هي دون تغيير
  departments   Department[]
  distributions Distribution[]
  doctors       Doctor[]
  patients      Patient[]
  pharmacies    Pharmacy[]
  
  // علاقة المكان (Place)
  placeId       String?        @unique
  place         Place?         @relation("HospitalPlace", fields: [placeId], references: [id])

  @@index([type])
  @@index([region])
}
model Department {
  id          String    @id @default(uuid())
  name        String    // اسم القسم (مثل: غرفة العمليات)
  deptType    String    // نوع التخصص (مثل: الجراحة العامة)
  status      String    @default("يعمل بكفاءة") // الحالة التشغيلية
  description String?   // ملاحظات / وصف
  hospitalId  String
  createdAt   DateTime  @default(now())
  hospital    Hospital  @relation(fields: [hospitalId], references: [id])
  doctors     Doctor[]
  services    Service[]
}

model Service {
  id                  String               @id @default(uuid())
  createdAt           DateTime             @default(now())
  departmentId        String
  isAvailable         Boolean              @default(true)
  name                String
  price               Float                @default(0.0)
  institutionServices InstitutionService[]
  department          Department           @relation(fields: [departmentId], references: [id])
}
model Doctor {
  id           String      @id @default(uuid())
  name         String
  phone        String
  specialty    String      // التخصص
  workSchedule String      // <--- هذا الحقل الذي يجب إضافته (مواعيد العمل)
  description  String?
  hospitalId   String
  departmentId String?
  createdAt    DateTime    @default(now())
  department   Department? @relation(fields: [departmentId], references: [id])
  hospital     Hospital    @relation(fields: [hospitalId], references: [id])
}
model Patient {
  id          String   @id @default(uuid())
  name        String
  phone       String
  diseaseType String
  hospitalId  String
  createdAt   DateTime @default(now())
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
}

model Pharmacy {
  id              String   @id @default(uuid())
  name            String
  phone           String
  availableMeds   String?
  unavailableMeds String?
  hospitalId      String
  createdAt       DateTime @default(now())
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
}

model Address {
  id          String    @id @default(uuid())
  title       String    // اسم المنطقة (مثل: البريج، النصيرات، الرمال)
  region      Region    // الموقع العام (NORTH, SOUTH, WEST, EAST, CENTRAL)
  description String?
  createdAt   DateTime  @default(now())
  
  // علاقة: العنوان الواحد (المنطقة) يمكن أن يحتوي على عدة مستشفيات
  hospitals   Hospital[] 

  // الإبقاء على علاقتك القديمة مع المخيمات إذا كانت مطلوبة
  campId      String?
  camp        Camps?    @relation(fields: [campId], references: [id])
}


model Institution {
  id                  String               @id @default(uuid())
  name                String
  email               String?
  createdAt           DateTime             @default(now())
  isProtected         Boolean              @default(false)
  isTrashed           Boolean              @default(false)
  latitude            Decimal?             @db.Decimal(10, 7)
  longitude           Decimal?             @db.Decimal(10, 7)
  placeId             String?              @unique
  presence            PresenceStatus       @default(AVAILABLE)
  serviceType         String?
  status              GeneralStatus        @default(ACTIVE)
  updatedAt           DateTime             @updatedAt
  contacts            Contact[]
  distributions       Distribution[]
  enterpriseProducts  EnterpriseProduct[]
  place               Place?               @relation("InstitutionPlace", fields: [placeId], references: [id])
  institutionProducts InstitutionProduct[]
  institutionServices InstitutionService[]

  @@index([status])
  @@index([presence])
  @@index([isTrashed])
}

model Beneficiary {
  id             String              @id @default(uuid())
  name           String
  phone          String              @unique
  numberOfFamily Int                 @default(0)
  priority       BeneficiaryPriority @default(NORMAL)
  area           String?
  campId         String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  role           String              @default("CITIZEN")
  isActive       Boolean             @default(true)
  isTrashed      Boolean             @default(false)
  isProtected    Boolean             @default(false)
  camp           Camps?              @relation(fields: [campId], references: [id])
  contacts       Contact[]
  distributions  Distribution[]

  @@index([campId])
  @@index([area])
  @@index([name])
  @@index([phone])
  @@index([isActive])
  @@index([isTrashed])
}

model Aid {
  id            String         @id @default(uuid())
  aidType       String
  aidName       String
  quantity      Int
  dateReceived  DateTime
  donor         String?
  status        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  distributions Distribution[]
}

model Distribution {
  id            String             @id @default(uuid())
  institutionId String
  quantity      Int                @default(0)
  aidId         String?
  beneficiaryId String?
  hospitalId    String?
  placeId       String?
  productId     String?
  status        DistributionStatus @default(PENDING)
  aid           Aid?               @relation(fields: [aidId], references: [id])
  beneficiary   Beneficiary?       @relation(fields: [beneficiaryId], references: [id])
  hospital      Hospital?          @relation(fields: [hospitalId], references: [id])
  institution   Institution        @relation(fields: [institutionId], references: [id])
  place         Place?             @relation("PlaceDistribution", fields: [placeId], references: [id])
  product       Product?           @relation(fields: [productId], references: [id])
}

model Product {
  id                  String               @id @default(uuid())
  nameAr              String
  price               Float                @default(0)
  quantity            Int                  @default(0)
  status              ProductStatus        @default(GHAIR_MOJOUD)
  distributions       Distribution[]
  enterpriseProducts  EnterpriseProduct[]
  institutionProducts InstitutionProduct[]
}

model InstitutionService {
  id            String      @id @default(uuid())
  institutionId String
  serviceId     String
  status        String      @default("مفعل")
  institution   Institution @relation(fields: [institutionId], references: [id])
  service       Service     @relation(fields: [serviceId], references: [id])

  @@unique([institutionId, serviceId])
}

model InstitutionProduct {
  id            String      @id @default(uuid())
  institutionId String
  productId     String
  institution   Institution @relation(fields: [institutionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@unique([institutionId, productId])
}

model Place {
  id            String         @id @default(uuid())
  name          String
  type          PlaceType
  description   String?
  latitude      Decimal        @db.Decimal(10, 7)
  longitude     Decimal        @db.Decimal(10, 7)
  status        PlaceStatus    @default(AVAILABLE)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  isTrashed     Boolean        @default(false)
  isProtected   Boolean        @default(false)
  operator      String?
  capacity      Int?
  occupancy     Int?
  availableBeds Int?
  statusText    String?
  camp          Camps?         @relation("CampPlace")
  distributions Distribution[] @relation("PlaceDistribution")
  hospital      Hospital?      @relation("HospitalPlace")
  institution   Institution?   @relation("InstitutionPlace")
  shelter       Shelter?       @relation("ShelterPlace")

  @@index([type])
  @@index([status])
  @@index([isActive])
  @@index([isTrashed])
  @@index([name])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id          String   @id @default(uuid())
  userId      String
  createdAt   DateTime @default(now())
  entityId    String?
  entityType  String?
  event       String?
  description String?
  ipAddress   String?
  meta        String?
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Contact {
  id            String        @id @default(uuid())
  institutionId String
  type          String?
  beneficiaryId String
  date          DateTime      @default(now())
  notes         String?
  status        ContactStatus @default(NOT_DONE)
  beneficiary   Beneficiary   @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([beneficiaryId])
  @@index([institutionId])
}

model Emergency {
  id            String          @id @default(uuid())
  description   String?
  campId        String
  emergencyType String
  level         EmergencyLevel  @default(MEDIUM)
  supervisorId  String
  status        EmergencyStatus @default(NEW)
  camp          Camps           @relation(fields: [campId], references: [id], onDelete: Cascade)
  supervisor    Supervisor      @relation(fields: [supervisorId], references: [id])
}

model EnterpriseProduct {
  id            String                        @id @default(uuid())
  institutionId String
  productId     String
  quantity      Int                           @default(0)
  availability  EnterpriseProductAvailability @default(AVAILABLE)
  institution   Institution                   @relation(fields: [institutionId], references: [id])
  product       Product                       @relation(fields: [productId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemSetting {
  id                             String   @id @default(uuid())
  name                           String   @default("AidMap")
  language                       String   @default("ar")
  timezone                       String   @default("Asia/Gaza")
  active                         Boolean  @default(true)
  address                        String?
  currency                       String   @default("ILS")
  currencyFormat                 String   @default("₪ {value}")
  logo                           String?
  notifyNewOrderEmail            Boolean  @default(true)
  notifyNewOrderRoleIds          String[]
  notifyNewOrderWeb              Boolean  @default(true)
  notifyOrderStatusUpdateEmail   Boolean  @default(true)
  notifyOrderStatusUpdateRoleIds String[]
  notifyOrderStatusUpdateWeb     Boolean  @default(true)
  notifyPaymentFailureEmail      Boolean  @default(true)
  notifyPaymentFailureRoleIds    String[]
  notifyPaymentFailureWeb        Boolean  @default(true)
  notifyStockEmail               Boolean  @default(true)
  notifyStockRoleIds             String[]
  notifyStockThreshold           Int      @default(10)
  notifyStockWeb                 Boolean  @default(true)
  notifySystemErrorFailureEmail  Boolean  @default(true)
  notifySystemErrorRoleIds       String[]
  notifySystemErrorWeb           Boolean  @default(true)
  socialFacebook                 String?
  socialInstagram                String?
  socialLinkedIn                 String?
  socialPinterest                String?
  socialTwitter                  String?
  socialYoutube                  String?
  supportEmail                   String?
  supportPhone                   String?
  websiteURL                     String?
}

model DistributeAidForm {
  id               String                  @id @default(uuid())
  beneficiaryName  String
  aidType          String
  quantity         Int
  status           DistributeAidFormStatus @default(SCHEDULED)
  createdAt        DateTime                @default(now())
  distributionDate DateTime
  institutionId    String?
  notes            String?
  updatedAt        DateTime                @updatedAt

  @@index([beneficiaryName])
  @@index([aidType])
  @@index([status])
  @@index([distributionDate])
}

model RequestAid {
  id          String             @id @default(uuid())
  fullName    String
  nationalId  String
  phone       String
  aidType     String
  familyCount Int
  address     String
  notes       String?
  status      DistributionStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum UserStatus {
  INACTIVE
  ACTIVE
  BLOCKED
}

enum CampFillStatus {
  NOT_FULL
  FULL
}

enum GeneralStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum BeneficiaryPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum EmergencyStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum EmergencyLevel {
  LOW
  MEDIUM
  HIGH
}

enum PlaceType {
  SHELTER
  MEDICAL
  WATER_POINT
  FOOD_SUPPORT_CENTER
}

enum PlaceStatus {
  AVAILABLE
  FULL
  UNAVAILABLE
}

enum PresenceStatus {
  AVAILABLE
  UNAVAILABLE
}

enum ContactStatus {
  DONE
  NOT_DONE
}

enum DistributionStatus {
  PENDING
  DONE
  CANCELED
}

enum EnterpriseProductAvailability {
  AVAILABLE
  UNAVAILABLE
}

enum DistributeAidFormStatus {
  SCHEDULED
  DONE
  CANCELED
}

enum ProductStatus {
  MOJOUD
  GHAIR_MOJOUD
}

enum HospitalType {
  PRIVATE
  UNRWA
  GOVERNMENT
}

enum Region {
  NORTH
  SOUTH
  EAST
  WEST
}
