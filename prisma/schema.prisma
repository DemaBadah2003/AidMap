generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  password        String?
  country         String?
  timezone        String?
  name            String?
  roleId          String
  status          UserStatus  @default(INACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastSignInAt    DateTime?
  emailVerifiedAt DateTime?
  isTrashed       Boolean     @default(false)
  avatar          String?
  invitedByUserId String?
  isProtected     Boolean     @default(false)
  language        String?     @default("en")
  theme           String?     @default("light")
  accounts        Account[]
  Session         Session[]
  systemLog       SystemLog[]
  role            UserRole    @relation(fields: [roleId], references: [id])

  @@index([invitedByUserId])
  @@index([roleId])
  @@index([status])
}

model UserRole {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String               @unique
  description     String?
  isTrashed       Boolean              @default(false)
  createdByUserId String?
  createdAt       DateTime             @default(now())
  isProtected     Boolean              @default(false)
  isDefault       Boolean              @default(false)
  users           User[]
  permissions     UserRolePermission[]
}

model UserPermission {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String
  description     String?
  createdByUserId String?
  createdAt       DateTime             @default(now())
  roles           UserRolePermission[]
}

model UserRolePermission {
  id           String         @id @default(uuid())
  roleId       String
  permissionId String
  assignedAt   DateTime       @default(now())
  permission   UserPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         UserRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], name: "provider_providerAccountId")
}

model Shelter {
  id            String         @id @default(uuid())
  name          String
  area          String
  phone         String
  familiesCount Int            @default(0)
  capacity      Int            @default(0)
  fillStatus    CampFillStatus @default(NOT_FULL)
  supervisorId  String
  placeId       String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  isTrashed     Boolean        @default(false)
  isProtected   Boolean        @default(false)

  supervisor Supervisor @relation(fields: [supervisorId], references: [id])
  place      Place?     @relation("ShelterPlace", fields: [placeId], references: [id])

  @@index([supervisorId])
  @@index([fillStatus])
  @@index([name])
  @@index([area])
  @@index([isTrashed])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemLog {
  id          String   @id @default(uuid())
  userId      String
  createdAt   DateTime @default(now())
  entityId    String?
  entityType  String?
  event       String?
  description String?
  ipAddress   String?
  meta        String?
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SystemSetting {
  id                             String   @id @default(uuid())
  name                           String   @default("My Company")
  logo                           String?
  active                         Boolean  @default(true)
  address                        String?
  websiteURL                     String?
  supportEmail                   String?
  supportPhone                   String?
  language                       String   @default("en")
  timezone                       String   @default("UTC")
  currency                       String   @default("USD")
  currencyFormat                 String   @default("$ {value}")
  socialFacebook                 String?
  socialTwitter                  String?
  socialInstagram                String?
  socialLinkedIn                 String?
  socialPinterest                String?
  socialYoutube                  String?
  notifyStockEmail               Boolean  @default(true)
  notifyStockWeb                 Boolean  @default(true)
  notifyStockThreshold           Int      @default(10)
  notifyStockRoleIds             String[]
  notifyNewOrderEmail            Boolean  @default(true)
  notifyNewOrderWeb              Boolean  @default(true)
  notifyNewOrderRoleIds          String[]
  notifyOrderStatusUpdateEmail   Boolean  @default(true)
  notifyOrderStatusUpdateWeb     Boolean  @default(true)
  notifyOrderStatusUpdateRoleIds String[]
  notifyPaymentFailureEmail      Boolean  @default(true)
  notifyPaymentFailureWeb        Boolean  @default(true)
  notifyPaymentFailureRoleIds    String[]
  notifySystemErrorFailureEmail  Boolean  @default(true)
  notifySystemErrorWeb           Boolean  @default(true)
  notifySystemErrorRoleIds       String[]
}

model Supervisor {
  id          String        @id @default(uuid())
  name        String
  phone       String?
  status      GeneralStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  isTrashed   Boolean       @default(false)
  isProtected Boolean       @default(false)
  camps       Camps[]
  shelters    Shelter[]

  emergencies Emergency[]

  @@index([status])
}

model Camps {
  id                   String         @id @default(uuid())
  name                 String // يمثل nameAr في الفرونت
  area                 String? // المنطقة (شمال، جنوب، إلخ)
  subArea              String? // الموقع الفرعي (جباليا، رفح، إلخ) - مضاف
  capacity             Int            @default(0)
  currentFamiliesCount Int            @default(0) // عدد العائلات الحالي - مضاف
  status               CampFillStatus @default(NOT_FULL)

  // الإحداثيات (اختياري حسب الكود الحالي)
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  // العلاقات
  supervisorId String? // جعلته اختياري إذا كان الفرونت لا يرسله حالياً
  placeId      String? @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isTrashed   Boolean  @default(false)
  isProtected Boolean  @default(false)

  // العلاقات الأخرى
  addresses     Address[]
  beneficiaries Beneficiary[]
  place         Place?        @relation("CampPlace", fields: [placeId], references: [id])
  supervisor    Supervisor?   @relation(fields: [supervisorId], references: [id])
  emergencies   Emergency[]

  @@index([supervisorId])
  @@index([status])
}

model Beneficiary {
  id             String              @id @default(uuid())
  name           String
  phone          String              @unique
  numberOfFamily Int                 @default(0)
  priority       BeneficiaryPriority @default(NORMAL)

  // الحقل الجديد
  area String? // المنطقة: شمال، جنوب، شرق، غرب

  campId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          String         @default("CITIZEN")
  isActive      Boolean        @default(true)
  isTrashed     Boolean        @default(false)
  isProtected   Boolean        @default(false)
  camp          Camps?         @relation(fields: [campId], references: [id])
  contacts      Contact[]
  distributions Distribution[]

  @@index([campId])
  @@index([area]) // أضفنا اندكس هنا لسرعة الفلترة حسب المنطقة
  @@index([name])
  @@index([phone])
  @@index([isActive])
  @@index([isTrashed])
}

model Aid {
  id            String         @id @default(uuid())
  aidType       String
  aidName       String
  quantity      Int
  dateReceived  DateTime
  donor         String?
  status        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  distributions Distribution[]
}

model Address {
  id          String   @id @default(uuid())
  governorate String?
  city        String?
  campId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  camp        Camps?   @relation(fields: [campId], references: [id])
}

model Emergency {
  id            String          @id @default(uuid())
  emergencyType String
  description   String?
  status        EmergencyStatus @default(NEW)
  level         EmergencyLevel  @default(MEDIUM)
  campId        String
  supervisorId  String
  camp          Camps           @relation(fields: [campId], references: [id], onDelete: Cascade)
  supervisor    Supervisor      @relation(fields: [supervisorId], references: [id])
}

model Clinic {
  id             String         @id @default(uuid())
  name           String
  specialty      String?
  capacityPerDay Int            @default(0)
  status         ClinicStatus   @default(OPEN)
  institutionId  String?
  placeId        String?        @unique
  institution    Institution?   @relation(fields: [institutionId], references: [id])
  place          Place?         @relation("ClinicPlace", fields: [placeId], references: [id])
  distributions  Distribution[]
}

model Institution {
  id                  String               @id @default(uuid())
  name                String
  instagramId         String?              @unique
  email               String?
  serviceType         String?
  presence            PresenceStatus       @default(AVAILABLE)
  status              GeneralStatus        @default(ACTIVE)
  latitude            Decimal?             @db.Decimal(10, 7)
  longitude           Decimal?             @db.Decimal(10, 7)
  placeId             String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isTrashed           Boolean              @default(false)
  isProtected         Boolean              @default(false)
  clinics             Clinic[]
  contacts            Contact[]
  distributions       Distribution[]
  enterpriseProducts  EnterpriseProduct[]
  place               Place?               @relation("InstitutionPlace", fields: [placeId], references: [id])
  institutionProducts InstitutionProduct[]
  institutionServices InstitutionService[]

  @@index([status])
  @@index([presence])
  @@index([isTrashed])
}

model Contact {
  id            String        @id @default(uuid())
  beneficiaryId String
  institutionId String
  status        ContactStatus @default(NOT_DONE)
  beneficiary   Beneficiary   @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model Product {
  id                  String               @id @default(uuid())
  name                String
  quantity            Int                  @default(0)
  status              ActiveStatus         @default(ACTIVE)
  distributions       Distribution[]
  enterpriseProducts  EnterpriseProduct[]
  institutionProducts InstitutionProduct[]
}

model Service {
  id                  String               @id @default(uuid())
  serviceType         String
  status              GeneralStatus        @default(ACTIVE)
  institutionServices InstitutionService[]
}

model InstitutionService {
  id            String      @id @default(uuid())
  institutionId String
  serviceId     String
  institution   Institution @relation(fields: [institutionId], references: [id])
  service       Service     @relation(fields: [serviceId], references: [id])

  @@unique([institutionId, serviceId])
}

model InstitutionProduct {
  id            String      @id @default(uuid())
  institutionId String
  productId     String
  institution   Institution @relation(fields: [institutionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@unique([institutionId, productId])
}

model Distribution {
  id            String             @id @default(uuid())
  beneficiaryId String?
  institutionId String
  productId     String?
  quantity      Int                @default(0)
  status        DistributionStatus @default(PENDING)
  aidId         String?
  clinicId      String?
  placeId       String?
  aid           Aid?               @relation(fields: [aidId], references: [id])
  beneficiary   Beneficiary?       @relation(fields: [beneficiaryId], references: [id])
  clinic        Clinic?            @relation(fields: [clinicId], references: [id])
  institution   Institution        @relation(fields: [institutionId], references: [id])
  place         Place?             @relation(fields: [placeId], references: [id])
  product       Product?           @relation(fields: [productId], references: [id])
}

model Place {
  id            String      @id @default(uuid())
  name          String
  type          PlaceType
  description   String?
  latitude      Decimal     @db.Decimal(10, 7)
  longitude     Decimal     @db.Decimal(10, 7)
  status        PlaceStatus @default(AVAILABLE)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isTrashed     Boolean     @default(false)
  isProtected   Boolean     @default(false)
  operator      String?
  capacity      Int?
  occupancy     Int?
  availableBeds Int?
  statusText    String?
  camp          Camps?      @relation("CampPlace")
  clinic        Clinic?     @relation("ClinicPlace")
  shelter       Shelter?    @relation("ShelterPlace")

  distributions Distribution[]
  institution   Institution?   @relation("InstitutionPlace")

  @@index([type])
  @@index([status])
  @@index([isActive])
  @@index([isTrashed])
  @@index([name])
}

model DistributeAidForm {
  id               String                  @id @default(uuid())
  beneficiaryName  String
  aidType          String
  quantity         Int
  status           DistributeAidFormStatus @default(SCHEDULED)
  createdAt        DateTime                @default(now())
  distributionDate DateTime
  institutionId    String?
  notes            String?
  updatedAt        DateTime                @updatedAt

  @@index([beneficiaryName])
  @@index([aidType])
  @@index([status])
  @@index([distributionDate])
}

model EnterpriseProduct {
  id            String                        @id @default(uuid())
  institutionId String
  productId     String
  quantity      Int                           @default(0)
  availability  EnterpriseProductAvailability @default(AVAILABLE)
  institution   Institution                   @relation(fields: [institutionId], references: [id])
  product       Product                       @relation(fields: [productId], references: [id])
}

model RequestAid {
  id          String             @id @default(uuid())
  fullName    String
  nationalId  String
  phone       String
  aidType     String
  familyCount Int
  address     String
  notes       String?
  status      DistributionStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum UserStatus {
  INACTIVE
  ACTIVE
  BLOCKED
}

enum CampFillStatus {
  NOT_FULL
  FULL
}

enum GeneralStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum BeneficiaryPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum EmergencyStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum EmergencyLevel {
  LOW
  MEDIUM
  HIGH
}

enum PlaceType {
  SHELTER
  MEDICAL
  WATER_POINT
  FOOD_SUPPORT_CENTER
}

enum PlaceStatus {
  AVAILABLE
  FULL
  UNAVAILABLE
}

enum ClinicStatus {
  OPEN
  CLOSED
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum PresenceStatus {
  AVAILABLE
  UNAVAILABLE
}

enum ContactStatus {
  DONE
  NOT_DONE
}

enum DistributionStatus {
  PENDING
  DONE
  CANCELED
}

enum EnterpriseProductAvailability {
  AVAILABLE
  UNAVAILABLE
}

enum DistributeAidFormStatus {
  SCHEDULED
  DONE
  CANCELED
}
