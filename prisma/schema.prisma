generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- إدارة المستخدمين والصلاحيات (User Management) ---

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  password        String?
  country         String?
  timezone        String?
  name            String?
  roleId          String
  status          UserStatus  @default(INACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastSignInAt    DateTime?
  emailVerifiedAt DateTime?
  isTrashed       Boolean     @default(false)
  avatar          String?
  invitedByUserId String?
  isProtected     Boolean     @default(false)
  language        String?     @default("en")
  theme           String?     @default("light")
  accounts        Account[]
  Session         Session[]
  systemLog       SystemLog[]
  role            UserRole    @relation(fields: [roleId], references: [id])

  @@index([invitedByUserId])
  @@index([roleId])
  @@index([status])
}

model UserRole {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String               @unique
  description     String?
  isTrashed       Boolean              @default(false)
  createdByUserId String?
  createdAt       DateTime             @default(now())
  isProtected     Boolean              @default(false)
  isDefault       Boolean              @default(false)
  users           User[]
  permissions     UserRolePermission[]
}

model UserPermission {
  id              String               @id @default(uuid())
  slug            String               @unique
  name            String
  description     String?
  createdByUserId String?
  createdAt       DateTime             @default(now())
  roles           UserRolePermission[]
}

model UserRolePermission {
  id           String         @id @default(uuid())
  roleId       String
  permissionId String
  assignedAt   DateTime       @default(now())
  permission   UserPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         UserRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], name: "provider_providerAccountId")
}

// --- النظام التعليمي وخدمات الطلاب (Education & Student Services) ---

model PsychologicalSupport {
  id           String   @id @default(uuid())
  centerName   String   // اسم المركز
  specialist   String   // الأخصائي
  phoneNumber  String   // رقم الهاتف (بدلاً من contactInfo)
  appointments String   // المواعيد العامة
  serviceType  String   // نوع الخدمة
  capacity     Int      @default(0) // السعة
  currentCount Int      @default(0) // عدد الموجود (بدلاً من casesCount)
  status       String   @default("متاح") // الحالة (متاح/ممتلئ)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isTrashed    Boolean  @default(false)

  @@index([centerName])
  @@index([specialist])
}
// تم تغيير الاسم من WifiPoint إلى Internet
model Internet {
  id           String   @id @default(uuid())
  placeName    String   // اسم المكان
  powerSource  String   // مصدر الطاقة
  wifiQuality  String   // جودة الإنترنت
  seatsCount   Int      @default(0) // عدد الكراسي
  isFree       String   // مجانية أم بمقابل
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isTrashed    Boolean  @default(false)

  // علاقة مع نموذج Place إذا كنت تريد ربطها بالخريطة
  placeId      String?  @unique
  place        Place?   @relation("InternetPlace", fields: [placeId], references: [id])

  @@index([placeName])
  @@index([wifiQuality])
}

model StudentIssue {
  id          String   @id @default(uuid())
  issueType   String   
  level       String   
  studentName String   
  schoolName  String   
  status      String   
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isTrashed   Boolean  @default(false)

  @@index([studentName])
}

model School {
  id          String   @id @default(uuid())
  name        String   
  location    String?  
  region      String?  
  level       String?  
  studyDays   String?  
  timing      String?  
  fees        Float    @default(0) 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isTrashed   Boolean  @default(false)
}

model Student {
  id            String   @id @default(uuid())
  name          String   
  nationalId    String   @unique 
  level         String   
  birthDate     DateTime 
  guardianName  String   
  guardianPhone String   
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isTrashed     Boolean  @default(false)
}

// --- نظام الإيواء والمخيمات (Shelter & Camps) ---

model Shelter {
  id            String         @id @default(uuid())
  supervisorId  String
  name          String
  capacity      Int            @default(0)
  area          String
  createdAt     DateTime       @default(now())
  familiesCount Int            @default(0)
  fillStatus    CampFillStatus @default(NOT_FULL)
  isProtected   Boolean        @default(false)
  isTrashed     Boolean        @default(false)
  phone         String
  placeId       String?        @unique
  updatedAt     DateTime       @updatedAt
  place         Place?         @relation("ShelterPlace", fields: [placeId], references: [id])
  supervisor    Supervisor     @relation(fields: [supervisorId], references: [id])
}

model Camps {
  id                   String         @id @default(uuid())
  name                 String
  area                 String?
  subArea              String?
  capacity             Int            @default(0)
  currentFamiliesCount Int            @default(0)
  status               CampFillStatus @default(NOT_FULL)
  latitude             Decimal?       @db.Decimal(10, 7)
  longitude            Decimal?       @db.Decimal(10, 7)
  supervisorId         String?
  placeId              String?        @unique
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  isTrashed            Boolean        @default(false)
  isProtected          Boolean        @default(false)
  addresses            Address[]
  citizens             Citizens[]
  place                Place?         @relation("CampPlace", fields: [placeId], references: [id])
  supervisor           Supervisor?    @relation(fields: [supervisorId], references: [id])
  emergencies          Emergency[]
}

model Supervisor {
  id          String        @id @default(uuid())
  name        String
  phone       String?
  area        String?
  createdAt   DateTime      @default(now())
  isProtected Boolean       @default(false)
  isTrashed   Boolean       @default(false)
  status      GeneralStatus @default(ACTIVE)
  updatedAt   DateTime      @updatedAt
  camps       Camps[]
  emergencies Emergency[]
  shelters    Shelter[]
}

// --- المنظومة الصحية (Medical System) ---

model Hospital {
  id        String       @id @default(uuid())
  type      HospitalType
  name      String
  region    Region
  phone     String
  latitude  Decimal?     @db.Decimal(10, 7)
  longitude Decimal?     @db.Decimal(10, 7)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  addressId String
  address   Address @relation(fields: [addressId], references: [id])

  departments   Department[]
  distributions Distribution[]
  doctors       Doctor[]
  patients      Patient[]

  placeId String? @unique
  place   Place?  @relation("HospitalPlace", fields: [placeId], references: [id])
}

model Department {
  id          String   @id @default(uuid())
  name        String
  deptType    String
  status      String   @default("يعمل بكفاءة")
  description String?
  hospitalId  String
  createdAt   DateTime @default(now())
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
  doctors     Doctor[]
  services    Service[]
}

model Service {
  id                  String               @id @default(uuid())
  createdAt           DateTime             @default(now())
  departmentId        String
  isAvailable         Boolean              @default(true)
  name                String
  price               Float                @default(0.0)
  institutionServices InstitutionService[]
  department          Department           @relation(fields: [departmentId], references: [id])
}

model Doctor {
  id           String      @id @default(uuid())
  name         String
  phone        String
  specialty    String
  workSchedule String
  description  String?
  hospitalId   String
  departmentId String?
  createdAt    DateTime    @default(now())
  department   Department? @relation(fields: [departmentId], references: [id])
  hospital     Hospital    @relation(fields: [hospitalId], references: [id])
}

model Patient {
  id          String   @id @default(uuid())
  name        String
  nationalId  String   @unique
  age         String
  address     String
  phone       String
  diseaseType String?
  hospitalId  String
  createdAt   DateTime @default(now())
  hospital    Hospital @relation(fields: [hospitalId], references: [id])
}

// --- نظام الموارد (Water & Food Points) ---

model WaterPoint {
  id        String           @id @default(uuid())
  name      String
  type      WaterType        @default(SWEET)
  status    WaterPointStatus @default(OPERATIONAL)
  
  placeId   String?          @unique
  place     Place?           @relation("WaterPointPlace", fields: [placeId], references: [id])
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}


model FoodPoint {
  id          String          @id @default(uuid())
  name        String
  location    String?
  region      String?
  serviceType FoodServiceType @default(HOT_MEALS)
  status      FoodPointStatus @default(OPERATIONAL)
  
  placeId     String?          @unique
  place       Place?           @relation("FoodPointPlace", fields: [placeId], references: [id])
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// --- البنية التحتية واللوجستيات (Infrastructure & Logistics) ---

model Address {
  id          String   @id @default(uuid())
  title       String
  region      Region
  description String?
  createdAt   DateTime @default(now())

  hospitals Hospital[]

  campId String?
  camp   Camps?  @relation(fields: [campId], references: [id])
}

model Institution {
  id                  String               @id @default(uuid())
  name                String
  email               String?
  createdAt           DateTime             @default(now())
  isProtected         Boolean              @default(false)
  isTrashed           Boolean              @default(false)
  latitude            Decimal?             @db.Decimal(10, 7)
  longitude           Decimal?             @db.Decimal(10, 7)
  placeId             String?              @unique
  presence            PresenceStatus       @default(AVAILABLE)
  serviceType         String?
  status              GeneralStatus        @default(ACTIVE)
  updatedAt           DateTime             @updatedAt
  contacts            Contact[]
  distributions       Distribution[]
  enterpriseProducts  EnterpriseProduct[]
  place               Place?               @relation("InstitutionPlace", fields: [placeId], references: [id])
  institutionProducts InstitutionProduct[]
  institutionServices InstitutionService[]
}

model Citizens {
  id             String              @id @default(uuid())
  name           String
  idNumber       String?             @unique
  phone          String              @unique
  numberOfFamily Int                 @default(0)
  priority       BeneficiaryPriority @default(NORMAL)
  area           String?
  campId         String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  role           String              @default("CITIZEN")
  isActive       Boolean             @default(true)
  isTrashed      Boolean             @default(false)
  isProtected    Boolean             @default(false)
  camp           Camps?              @relation(fields: [campId], references: [id])
  contacts       Contact[]
  distributions  Distribution[]
}

model Aid {
  id            String         @id @default(uuid())
  aidType       String
  aidName       String
  quantity      Int
  dateReceived  DateTime
  donor         String?
  status        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  distributions Distribution[]
}

model Distribution {
  id            String             @id @default(uuid())
  institutionId String
  quantity      Int                @default(0)
  aidId         String?
  citizenId     String?
  hospitalId    String?
  placeId       String?
  productId     String?
  status        DistributionStatus @default(PENDING)
  aid           Aid?               @relation(fields: [aidId], references: [id])
  citizen       Citizens?          @relation(fields: [citizenId], references: [id])
  hospital      Hospital?          @relation(fields: [hospitalId], references: [id])
  institution   Institution        @relation(fields: [institutionId], references: [id])
  place         Place?             @relation("PlaceDistribution", fields: [placeId], references: [id])
  product       Product?           @relation(fields: [productId], references: [id])
}

model Product {
  id                  String               @id @default(uuid())
  nameAr              String
  price               Float                @default(0)
  quantity            Int                  @default(0)
  status              ProductStatus        @default(GHAIR_MOJOUD)
  distributions       Distribution[]
  enterpriseProducts  EnterpriseProduct[]
  institutionProducts InstitutionProduct[]
}

model InstitutionService {
  id            String      @id @default(uuid())
  institutionId String
  serviceId     String
  status        String      @default("مفعل")
  institution   Institution @relation(fields: [institutionId], references: [id])
  service       Service     @relation(fields: [serviceId], references: [id])

  @@unique([institutionId, serviceId])
}

model InstitutionProduct {
  id            String      @id @default(uuid())
  institutionId String
  productId     String
  institution   Institution @relation(fields: [institutionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@unique([institutionId, productId])
}

model Place {
  id            String         @id @default(uuid())
  name          String
  type          PlaceType
  description   String?
  latitude      Decimal        @db.Decimal(10, 7)
  longitude     Decimal        @db.Decimal(10, 7)
  status        PlaceStatus    @default(AVAILABLE)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  isTrashed     Boolean        @default(false)
  isProtected   Boolean        @default(false)
  operator      String?
  capacity      Int?
  occupancy     Int?
  availableBeds Int?
  statusText    String?
  camp          Camps?         @relation("CampPlace")
  distributions Distribution[] @relation("PlaceDistribution")
  hospital      Hospital?      @relation("HospitalPlace")
  institution   Institution?   @relation("InstitutionPlace")
  shelter       Shelter?       @relation("ShelterPlace")
  waterPoint    WaterPoint?    @relation("WaterPointPlace")
  foodPoint     FoodPoint?     @relation("FoodPointPlace")
  internet      Internet?      @relation("InternetPlace") // تحديث العلاقة هنا
}

// --- النظام التقني (System & Logs) ---

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id          String   @id @default(uuid())
  userId      String
  createdAt   DateTime @default(now())
  entityId    String?
  entityType  String?
  event       String?
  description String?
  ipAddress   String?
  meta        String?
  user        User     @relation(fields: [userId], references: [id])
}

model Contact {
  id            String        @id @default(uuid())
  institutionId String
  type          String?
  citizenId     String
  date          DateTime      @default(now())
  notes         String?
  status        ContactStatus @default(NOT_DONE)
  citizen       Citizens      @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model Emergency {
  id            String          @id @default(uuid())
  description   String?
  campId        String
  emergencyType String
  level         EmergencyLevel  @default(MEDIUM)
  supervisorId  String
  status        EmergencyStatus @default(NEW)
  camp          Camps           @relation(fields: [campId], references: [id], onDelete: Cascade)
  supervisor    Supervisor      @relation(fields: [supervisorId], references: [id])
}

model EnterpriseProduct {
  id            String                        @id @default(uuid())
  institutionId String
  productId     String
  quantity      Int                           @default(0)
  availability  EnterpriseProductAvailability @default(AVAILABLE)
  institution   Institution                   @relation(fields: [institutionId], references: [id])
  product       Product                       @relation(fields: [productId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemSetting {
  id                             String   @id @default(uuid())
  name                           String   @default("AidMap")
  language                       String   @default("ar")
  timezone                       String   @default("Asia/Gaza")
  active                         Boolean  @default(true)
  address                        String?
  currency                       String   @default("ILS")
  currencyFormat                 String   @default("₪ {value}")
  logo                           String?
  notifyNewOrderEmail            Boolean  @default(true)
  notifyNewOrderRoleIds          String[]
  notifyNewOrderWeb              Boolean  @default(true)
  notifyOrderStatusUpdateEmail   Boolean  @default(true)
  notifyOrderStatusUpdateRoleIds String[]
  notifyOrderStatusUpdateWeb     Boolean  @default(true)
  notifyPaymentFailureEmail      Boolean  @default(true)
  notifyPaymentFailureRoleIds    String[]
  notifyPaymentFailureWeb        Boolean  @default(true)
  notifyStockEmail               Boolean  @default(true)
  notifyStockRoleIds             String[]
  notifyStockThreshold           Int      @default(10)
  notifyStockWeb                 Boolean  @default(true)
  notifySystemErrorFailureEmail  Boolean  @default(true)
  notifySystemErrorRoleIds       String[]
  notifySystemErrorWeb           Boolean  @default(true)
  socialFacebook                 String?
  socialInstagram                String?
  socialLinkedIn                 String?
  socialPinterest                String?
  socialTwitter                  String?
  socialYoutube                  String?
  supportEmail                   String?
  supportPhone                   String?
  websiteURL                     String?
}

model DistributeAidForm {
  id               String                  @id @default(uuid())
  citizenName      String
  aidType          String
  quantity         Int
  status           DistributeAidFormStatus @default(SCHEDULED)
  createdAt        DateTime                @default(now())
  distributionDate DateTime
  institutionId    String?
  notes            String?
  updatedAt        DateTime                @updatedAt
}

model RequestAid {
  id          String             @id @default(uuid())
  fullName    String
  nationalId  String
  phone       String
  aidType     String
  familyCount Int
  address     String
  notes       String?
  status      DistributionStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

// --- Enums ---

enum UserStatus {
  INACTIVE
  ACTIVE
  BLOCKED
}

enum CampFillStatus {
  NOT_FULL
  FULL
}

enum GeneralStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum BeneficiaryPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum EmergencyStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum EmergencyLevel {
  LOW
  MEDIUM
  HIGH
}

enum PlaceType {
  SHELTER
  MEDICAL
  WATER_POINT
  FOOD_SUPPORT_CENTER
}

enum PlaceStatus {
  AVAILABLE
  FULL
  UNAVAILABLE
}

enum PresenceStatus {
  AVAILABLE
  UNAVAILABLE
}

enum ContactStatus {
  DONE
  NOT_DONE
}

enum DistributionStatus {
  PENDING
  DONE
  CANCELED
}

enum EnterpriseProductAvailability {
  AVAILABLE
  UNAVAILABLE
}

enum DistributeAidFormStatus {
  SCHEDULED
  DONE
  CANCELED
}

enum ProductStatus {
  MOJOUD
  GHAIR_MOJOUD
}

enum HospitalType {
  PRIVATE
  UNRWA
  GOVERNMENT
}

enum Region {
  NORTH
  SOUTH
  EAST
  WEST
}

enum WaterType {
  SWEET
  SALTY
}

enum WaterPointStatus {
  OPERATIONAL
  STOPPED
}

enum FoodPointStatus {
  OPERATIONAL
  STOPPED
}

enum FoodServiceType {
  HOT_MEALS
  DRY_RATIONS
  BAKERY
}